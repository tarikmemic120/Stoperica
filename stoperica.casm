//Macro implementations



void main()

{
	//Initialization
	ansel = 0;
0255  1683  	BSF STATUS, RP0
0256  1703  	BSF STATUS, RP1
0257  0188  	CLRF gbl_ansel

anselh = 0;
0258  0189  	CLRF gbl_anselh



	//Interrupt initialization code
	option_reg = 0xC0;
0259  30C0  	MOVLW 0xC0
025A  1303  	BCF STATUS, RP1
025B  0081  	MOVWF gbl_option_reg



	//Call Component Macro
	//Call Component Macro: Start()
	FCD_LCDDisplay0_Start();
025C  2200  	CALL FCD_LCDDis_00052


	//Loop
	//Loop: While 1
	while (1)
025D        label35

	{

		//Call Component Macro
		//Call Component Macro: start=ReadState()
		FCV_START = FCD_SWITCH0_ReadState();
025D  20CB  	CALL FCD_SWITCH_0005D
025E  085C  	MOVF CompTempVarRet2223, W
