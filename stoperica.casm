void FCD_LCDDisplay0_ScrollDisplay(MX_UINT8 Direction, MX_UINT8 Num_Positions)
{
	
		MX_UINT8 cmd = 0;
		MX_UINT8 count;

		//Choose the direction
		switch (Direction)
		{
			case 0:
			case 'l':
			case 'L':

				cmd = 0x18;
				break;

			case 1:
			case 'r':
			case 'R':

				cmd = 0x1C;
				break;

			default:
				break;
		}

		//If direction accepted then scroll the specified amount
		if (cmd)
		{
			for (count = 0; count < Num_Positions; count++)
				FCD_LCDDisplay0_Command(cmd);
		}

}

void FCD_LCDDisplay0_ClearLine(MX_UINT8 Line)
{
	
		MX_UINT8 count;
		MX_UINT8 rowcount;

		//Define number of columns per line
		#if (LCD_1__ROWCNT == 1)
			rowcount=80;
		#endif

		#if (LCD_1__ROWCNT == 2)
			rowcount=40;
		#endif

		#if (LCD_1__ROWCNT == 4)
			#if (LCD_1__COLCNT == 16)
				rowcount=16;
			#endif
			#if (LCD_1__COLCNT == 20)
				rowcount=20;
			#endif
		#endif

		//Start at beginning of the line
		FCD_LCDDisplay0_Cursor (0, Line);

		//Send out spaces to clear line
		for (count = 0; count < rowcount; count++)
			FCD_LCDDisplay0_RawSend(' ', 0x10);

		//Move back to the beginning of the line.
		FCD_LCDDisplay0_Cursor (0, Line);

}

void FCD_LCDDisplay0_RAM_Write(MX_UINT8 nIdx, MX_UINT8 d0, MX_UINT8 d1, MX_UINT8 d2, MX_UINT8 d3, MX_UINT8 d4, MX_UINT8 d5, MX_UINT8 d6, MX_UINT8 d7)
{
	   //set CGRAM address

	   FCD_LCDDisplay0_RawSend(64 + (nIdx << 3), 0);
	   delay_ms(2);

	   //write CGRAM data
	   FCD_LCDDisplay0_RawSend(d0, 0x10);
	   FCD_LCDDisplay0_RawSend(d1, 0x10);
	   FCD_LCDDisplay0_RawSend(d2, 0x10);
	   FCD_LCDDisplay0_RawSend(d3, 0x10);
	   FCD_LCDDisplay0_RawSend(d4, 0x10);
	   FCD_LCDDisplay0_RawSend(d5, 0x10);
	   FCD_LCDDisplay0_RawSend(d6, 0x10);
	   FCD_LCDDisplay0_RawSend(d7, 0x10);

	   //Clear the display
	   FCD_LCDDisplay0_RawSend(0x01, 0);
	   delay_ms(2);
	   FCD_LCDDisplay0_RawSend(0x02, 0);
	   delay_ms(2);

}



//SWITCH(0): //Macro implementations


MX_UINT8 FCD_SWITCH0_ReadState()

{
	
		MX_UINT8 switchval = 255;
00CB  30FF  	MOVLW 0xFF
00CC  1283  	BCF STATUS, RP0
00CD  1303  	BCF STATUS, RP1
00CE  00DB  	MOVWF FCD_SWITCH_0005D_1_switchval


	  #if Switch_2_SW_DELAY > 0
		MX_UINT16 del_count;
		MX_UINT8 old_switchval;
	  #endif

		FC_CAL_Bit_In_DDR( Switch_2_SW_PORT , Switch_2_SW_TRIS , Switch_2_SW_PIN );		//Convert pin to input
00CF  1683  	BSF STATUS, RP0
00D0  1485  	BSF gbl_trisa,1

		switchval = FC_CAL_Bit_In( Switch_2_SW_PORT , Switch_2_SW_PIN );			//Sample input
00D1  3002  	MOVLW 0x02
00D2  1283  	BCF STATUS, RP0
00D3  0505  	ANDWF gbl_porta, W
00D4  00DB  	MOVWF FCD_SWITCH_0005D_1_switchval


	  #if (Switch_2_SW_POLE == 0)
		if (switchval)													//Invert logic if required
			switchval = 0;
		else
			switchval = 1;
	  #endif

	  #if (Switch_2_SW_DELAY > 0)

		del_count = 0;
		old_switchval = 255;

		while (del_count < Switch_2_SW_DELAY)									//Debounce input
		{
			Switch_2_SW_DEL;
			switchval = FC_CAL_Bit_In( Switch_2_SW_PORT , Switch_2_SW_PIN );		//Sample input

		  #if (Switch_2_SW_POLE == 0)
			if (switchval)												//Invert logic if required
				switchval = 0;
			else
				switchval = 1;
		  #endif

			if (switchval == old_switchval)								//Is switch the same state?
				del_count++;											//Increment counter
			else
				del_count = 0;											//Else reset counter

			old_switchval = switchval;									//Update the old state
		}
	  #endif

		return (switchval);												//Return state of switch as least significant bit
00D5  085B  	MOVF FCD_SWITCH_0005D_1_switchval, W
00D6  00DC  	MOVWF CompTempVarRet2223


}
00D7  0008  	RETURN


void FCD_SWITCH0_WaitUntilHigh()
{
	
		MX_UINT8 switchval = 255;

	  #if Switch_2_SW_DELAY > 0
		MX_UINT16 del_count;
		MX_UINT8 old_switchval;
	  #endif

		FC_CAL_Bit_In_DDR ( Switch_2_SW_PORT , Switch_2_SW_TRIS , Switch_2_SW_PIN );

		while (switchval != Switch_2_SW_POLE)										//While state not active
		{
			switchval = FC_CAL_Bit_In ( Switch_2_SW_PORT, Switch_2_SW_PIN );			//Convert pin to input

		  #if (Switch_2_SW_DELAY > 0)

		  	del_count = 0;
		  	old_switchval = 255;

			while (del_count < Switch_2_SW_DELAY)									//Debounce input
			{
				Switch_2_SW_DEL;
				switchval = FC_CAL_Bit_In ( Switch_2_SW_PORT , Switch_2_SW_PIN );		//Sample input

				if (switchval == old_switchval)								//Is switch the same state?
					del_count++;											//Increment counter
				else
					del_count = 0;											//Else reset counter

				old_switchval = switchval;									//Update the old state
			}
		  #endif
		}

}

void FCD_SWITCH0_WaitUntilLow()
{
	
		MX_UINT8 switchval = Switch_2_SW_POLE;

	  #if Switch_2_SW_DELAY > 0
		MX_UINT16 del_count = 0;
		MX_UINT8 old_switchval;
	  #endif

		FC_CAL_Bit_In_DDR ( Switch_2_SW_PORT, Switch_2_SW_TRIS , Switch_2_SW_PIN );			//Convert pin to input

		while (switchval == Switch_2_SW_POLE)										//While state active
		{
			switchval = FC_CAL_Bit_In ( Switch_2_SW_PORT, Switch_2_SW_PIN );			//Sample input

		  #if (Switch_2_SW_DELAY > 0)

		  	del_count = 0;
		  	old_switchval = 255;

			while (del_count < Switch_2_SW_DELAY)									//Debounce input
			{
				Switch_2_SW_DEL;
				switchval = FC_CAL_Bit_In ( Switch_2_SW_PORT, Switch_2_SW_PIN );		//Sample input

				if (switchval == old_switchval)								//Is switch the same state?
					del_count++;											//Increment counter
				else
					del_count = 0;											//Else reset counter

				old_switchval = switchval;									//Update the old state
			}
		  #endif
		}

}



